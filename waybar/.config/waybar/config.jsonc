{
  "layer": "top",
  "modules-left": ["hyprland/workspaces", "hyprland/submap"],
  "modules-center": ["clock"],
  "modules-right": [
    "tray",
    "group/audio",
    "group/hardware",
    "network",
    "group/group-power",
  ],
  "hyprland/workspaces": {
    "all-outputs": true,
    "show-special": true,
    "special-visible-only": true,
    "format": "{icon}",
    "format-icons": {
      "magic": "ï”›",
    },
  },
  "hyprland/submap": {
    "format": "ï€£",
    "tooltip": false,
  },
  "backlight": {
    "format": "{icon} {percent}%",
    // "format-icons": ["َ°‹™", "َ°«ƒ", "َ°«„", "َ°«…", "َ°«†", "َ°«‡", "َ°«ˆ"],
    // "format-icons": ["ًںŒ‘", "ًںŒک", "ًںŒ—", "ًںŒ–", "ًںŒ•"],
    "format-icons": ["َ°‌¦", "َ°ھ‍", "َ°ھں", "َ°ھ ", "َ°ھ،", "َ°ھ¢", "َ°ھ£", "َ°ھ¤", "َ°ھ¥"],
    "tooltip": false,
  },
  "battery": {
    "interval": 60,
    "states": {
      "warning": 20,
      "critical": 10,
    },
    "format": "{icon} {capacity}%",
    "format-charging": "َ°‚„ {capacity}%",
    "format-full": "",
    "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
    "tooltip-format": "{timeTo} - {power:.1f}W",
    "tooltip": true,
  },
  "bluetooth": {
    "format": "َ°‚¯",
    "format-off": "َ°‚²",
    "format-disabled": "َ°‚²",
    "format-on": "َ°‚¯",
    "format-connected": "َ°‚±{num_connections}",
    "tooltip-format": "{controller_alias} - {controller_address}",
    "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias} - {device_battery_percentage}%",
    "tooltip": true,
    "on-click": "ghostty --title=bluetui -e bluetui",
    "on-click-right": "ghostty --title=bluetui -e bluetui",
  },
  "cpu": {
    "interval": 5,
    "format": "ï‹› {usage}%",
    "max-length": 10,
    "on-click": "ghostty --title=btop -e btop -c $HOME/.config/btop/cpu-view.conf",
    "on-click-right": "ghostty --title=btop -e btop -c $HOME/.config/btop/cpu-view.conf",
    "states": {
      "warning": 75,
      "critical": 90,
    },
  },
  "clock": {
    "format": "َ°¥” {:%H:%M}",
    "format-alt": " {:%A, %d %B %Y - %H:%M}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "format": {
        "months": "<span color='#f5a97f'><b>{}</b></span>",
        "days": "<span color='#cad3f5'>{}</span>",
        "weeks": "<span color='#a6da95'><b>W{}</b></span>",
        "weekdays": "<span color='#eed49f'><b>{}</b></span>",
        "today": "<span color='#ed8796'><b><u>{}</u></b></span>",
      },
    },
    "actions": {
      "on-click-middle": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down",
    },
    "on-click-right": "xdg-open https://calendar.google.com/",
  },
  "memory": {
    "interval": 5,
    "format": "î؟… {percentage}%",
    "tooltip-format": "{used:0.1f}GB / {total:0.1f}GB ({percentage}%)",
    "states": {
      "warning": 75,
      "critical": 90,
    },
    "on-click": "ghostty --title=btop -e btop -c $HOME/.config/btop/memory-view.conf",
    "on-click-right": "ghostty --title=btop -e btop -c $HOME/.config/btop/memory-view.conf",
  },
  "network": {
    "interval": 3,
    "format-wifi": "ï‡«",
    "format-ethernet": "ïƒپ",
    "format-disconnected": "َ°–ھ",
    "format-disabled": "َ°–ھ",
    "format-linked": "َ°ˆ€",
    "format-alt": "َ°‡ڑ {bandwidthDownBytes} َ°•’ {bandwidthUpBytes}",
    "tooltip-format-wifi": "{essid} â€” {signalStrength}% ({signaldBm}dBm)\nَ°©ں {ipaddr}/{cidr}",
    "tooltip-format-ethernet": "َ°ˆ€ {ifname}\nَ°©ں {ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Disconnected",
    "on-click-right": "nmrs",
  },
  "wireplumber": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°‌ں",
    "format-icons": ["َ°•؟", "َ°–€", "َ°•¾"],
    "tooltip-format": "{node_name}",
    "scroll-step": 2,
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
    "on-click-right": "ghostty --title=wiremix -e wiremix -v playback",
  },
  "wireplumber#source": {
    "node-type": "Audio/Source",
    "format": "َ°چ¬ {volume}%",
    "format-muted": "َ°چ­",
    "tooltip-format": "{node_name}",
    "scroll-step": 2,
    "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
    "on-click-right": "ghostty --title=wiremix -e wiremix -v input",
  },
  "systemd-failed-units": {
    "hide-on-ok": false,
    "format": "âœ— {nr_failed}",
    "format-ok": "âœ“",
    "system": true,
    "user": true,
    "on-click": "ghostty --title=systemctl-tui -e systemctl-tui",
    "on-click-right": "ghostty --title=systemctl-tui -e systemctl-tui",
  },
  "temperature": {
    "hwmon-path-abs": "/sys/devices/platform/coretemp.0/hwmon",
    "input-filename": "temp1_input",
    "interval": 5,
    "warning-threshold": 75,
    "critical-threshold": 90,
    "format": "{icon} {temperatureC}آ°C",
    "format-icons": ["ï‹‹", "ï‹ٹ", "ï‹‰", "ï‹ˆ", "ï‹‡"],
    "tooltip": false,
  },
  "tray": {
    "icon-size": 18,
    "spacing": 8,
    "show-passive-items": true,
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "{profile}",
    "tooltip": true,
    "format-icons": {
      "default": "َ°ˆگ",
      "performance": "َ±گ‹",
      "balanced": "َ°¾…",
      "power-saver": "َ°Œھ",
    },
  },
  "group/audio": {
    "orientation": "inherit",
    "modules": ["wireplumber", "wireplumber#source"],
  },
  "group/hardware": {
    "orientation": "inherit",
    "modules": ["memory", "cpu", "temperature", "battery"],
  },
  "group/group-power": {
    "orientation": "inherit",
    "drawer": {
      "transition-duration": 500,
      "children-class": "group-power",
      "transition-left-to-right": false,
    },
    "modules": [
      "custom/powermenu",
      "backlight",
      "bluetooth",
      "power-profiles-daemon",
      "systemd-failed-units",
    ],
  },
  "custom/powermenu": {
    "format": "ï€‘",
    "tooltip": false,
    "on-click": "~/.config/wofi/power_option/powermenu.sh",
  },
}
