### Base settings ###
set selection-clipboard clipboard
set adjust-open "best-fit"
set pages-per-row 1
set scroll-page-aware true
set scroll-full-overlap 0.1

### Colors/appearance ###
set default-bg "#282828"
set default-fg "#ebdbb2"

### Key mappings ###

# Zoom
map K zoom in
map J zoom out

# Navigation
map h navigate previous
map l navigate next

map <Right> navigate next
map <Left> navigate previous

map u scroll half-up
map d scroll half-down

map H scroll left
map L scroll right

# Other
map D toggle_page_mode
map r reload
map R rotate

map i recolor
map p print
